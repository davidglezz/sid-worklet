{
  "name": "sid-worklet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "vp config",
    "dev": "vp dev",
    "build": "tsc && vp build",
    "preview": "vp preview",
    "format": "vp fmt --write .",
    "format-check": "vp fmt --check .",
    "lint": "vp lint . --fix",
    "lint-check": "vp lint .",
    "type-check": "tsc --noEmit --composite false",
    "test": "vp test run",
    "test:coverage": "vp test run --coverage",
    "bench": "vp test bench"
  },
  "dependencies": {
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.19"
  },
  "devDependencies": {
    "@types/audioworklet": "^0.0.54",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.19",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
